# Generated by 'sov init mesh tiered'. Adjust as you wish.
#
#   prime         :8080 (master gateway)
#     └ team      :9100 federates [Echo]
#         ├ pod-1 :9101
#         └ pod-2 :9102
#
#   docker compose up --build
#   curl -s -X POST http://localhost:8080/rpc/_introspect | jq
name: {{.Project}}-tiered

x-mesh-env: &mesh-env
  SOV_HMAC_SECRET: "${SOV_HMAC_SECRET}"
  SOV_MESH_SECRET: "${SOV_MESH_SECRET}"
  SOV_PRIME:       "http://prime:8080"

services:
  prime:
    build:
      context: .
      args:
        ROLE: prime
    environment:
      SOV_LISTEN: ":8080"
      SOV_ADVERTISE: "http://prime:8080"
      SOV_HMAC_SECRET: "${SOV_HMAC_SECRET}"
      SOV_MESH_SECRET: "${SOV_MESH_SECRET}"
    ports:
      - "8080:8080"

  team:
    build:
      context: .
      args:
        ROLE: team
    depends_on: [prime]
    environment:
      <<: *mesh-env
      SOV_LISTEN: ":9100"
      SOV_ADVERTISE: "http://team:9100"

  pod-1:
    build:
      context: .
      args:
        ROLE: pod
    depends_on: [team]
    environment:
      SOV_HMAC_SECRET: "${SOV_HMAC_SECRET}"
      SOV_MESH_SECRET: "${SOV_MESH_SECRET}"
      SOV_TEAM:      "http://team:9100"
      SOV_LISTEN:    ":9101"
      SOV_ADVERTISE: "http://pod-1:9101"

  pod-2:
    build:
      context: .
      args:
        ROLE: pod
    depends_on: [team]
    environment:
      SOV_HMAC_SECRET: "${SOV_HMAC_SECRET}"
      SOV_MESH_SECRET: "${SOV_MESH_SECRET}"
      SOV_TEAM:      "http://team:9100"
      SOV_LISTEN:    ":9102"
      SOV_ADVERTISE: "http://pod-2:9102"
