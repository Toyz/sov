// Code generated by 'sov init mesh tiered'. Adjust as you wish.
//
// Tiered mesh — team gateway. Federates a slice of services to prime
// and accepts registrations from the pods that actually host them.
package main

import (
	"context"
	"log"
	"os"
	"time"

	"github.com/Toyz/sov"
	"github.com/Toyz/sov/gateway/builtin/hmacseal"
	"github.com/Toyz/sov/gateway/builtin/meshsecret"
	"github.com/Toyz/sov/gateway/builtin/registry"
)

func main() {
	if err := sov.LoadEnv(".sov.env"); err != nil {
		log.Fatalf("{{.Project}}-team: load env: %v", err)
	}

	advertiseURL := envDefault("SOV_ADVERTISE", "http://team:9100")
	gw := sov.NewRegistry(sov.RegistryConfig{
		Registry:   registry.Config{AllowedNames: []string{"Echo"}},
		HMACSeal:   hmacseal.Config{Secret: []byte(os.Getenv("SOV_HMAC_SECRET"))},
		MeshSecret: meshsecret.Config{Secret: []byte(os.Getenv("SOV_MESH_SECRET"))},
	}, sov.WithTrustUpstreamClaims(true), sov.WithAdvertiseURL(advertiseURL))

	log.Fatal(gw.RunMesh(context.Background(), sov.MeshOptions{
		UpstreamURL:    envDefault("SOV_PRIME", "http://prime:8080"),
		Address:        envDefault("SOV_LISTEN", ":9100"),
		Advertise:      advertiseURL,
		Heartbeat:      5 * time.Second,
		Introspectable: true,
		MeshSecret:     []byte(os.Getenv("SOV_MESH_SECRET")),
		Federate:       []string{"Echo"},
	}))
}

func envDefault(k, def string) string {
	if v := os.Getenv(k); v != "" {
		return v
	}
	return def
}
