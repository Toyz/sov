# Generated by 'sov init mesh'. Adjust as you wish.
#
#   docker compose up --build
#   curl -X POST http://localhost:8080/rpc/_introspect
name: {{.Project}}-mesh

x-mesh-env: &mesh-env
  SOV_HMAC_SECRET: "${SOV_HMAC_SECRET}"
  SOV_MESH_SECRET: "${SOV_MESH_SECRET}"

services:
  gateway:
    build:
      context: .
      args:
        ROLE: gateway
    environment:
      SOV_LISTEN: ":8080"
      <<: *mesh-env
    ports:
      - "8080:8080"

  pod-1:
    build:
      context: .
      args:
        ROLE: pod
    depends_on: [gateway]
    environment:
      SOV_LISTEN: ":9001"
      SOV_ADVERTISE: "http://pod-1:9001"
      SOV_GATEWAY: "http://gateway:8080"
      <<: *mesh-env

  pod-2:
    build:
      context: .
      args:
        ROLE: pod
    depends_on: [gateway]
    environment:
      SOV_LISTEN: ":9002"
      SOV_ADVERTISE: "http://pod-2:9002"
      SOV_GATEWAY: "http://gateway:8080"
      <<: *mesh-env
