// Code generated by 'sov init mesh'. Adjust as you wish.
//
// Mesh gateway: registry role only. Pods register via _register and
// route through this gateway. Source .sov.env (generated by
// `sov init secrets`) so HMAC + mesh secrets match across the mesh.
package main

import (
	"context"
	"log"
	"os"

	"github.com/Toyz/sov"
	"github.com/Toyz/sov/gateway/builtin/hmacseal"
	"github.com/Toyz/sov/gateway/builtin/meshsecret"
	"github.com/Toyz/sov/gateway/builtin/registry"
)

func main() {
	if err := sov.LoadEnv(".sov.env"); err != nil {
		log.Fatalf("{{.Project}}-gateway: load env: %v", err)
	}

	addr := envDefault("SOV_LISTEN", ":8080")
	gw := sov.NewRegistry(sov.RegistryConfig{
		Registry:   registry.Config{AllowedNames: []string{"Echo"}},
		HMACSeal:   hmacseal.Config{Secret: []byte(os.Getenv("SOV_HMAC_SECRET"))},
		MeshSecret: meshsecret.Config{Secret: []byte(os.Getenv("SOV_MESH_SECRET"))},
	})

	log.Printf("{{.Project}} mesh gateway on %s", addr)
	if err := gw.Run(context.Background(), addr); err != nil {
		log.Fatal(err)
	}
}

func envDefault(k, def string) string {
	if v := os.Getenv(k); v != "" {
		return v
	}
	return def
}
